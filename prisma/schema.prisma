generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  disabled
}

enum TripStatus {
  draft
  planning
  active
  completed
  archived
}

enum TripMemberRole {
  owner
  admin
  member
  viewer
}

enum TripPlaceType {
  attraction
  hotel
  restaurant
  transport
  shopping
  custom
}

enum TripExpenseCategory {
  transport
  hotel
  food
  ticket
  parking
  shopping
  maintenance
  activity
  other
}

enum TravelDocumentType {
  passport
  visa
  flight
  hotel
  ticket
  insurance
  other
}

enum PackingListCategory {
  clothing
  toiletries
  electronics
  medicine
  documents
  other
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

model User {
  id            String             @id @default(cuid())
  username      String             @unique
  displayName   String             @map("display_name")
  passwordHash  String             @map("password_hash")
  avatarUrl     String?            @map("avatar_url")
  status        UserStatus         @default(active)
  lastLoginAt   DateTime?          @map("last_login_at")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  ownedTrips    Trip[]             @relation("TripOwner")
  tripMembers   TripMember[]
  paidExpenses  TripExpense[]      @relation("ExpensePayer")
  expenseShares TripExpenseShare[]

  @@map("users")
}

model Trip {
  id              String           @id @default(cuid())
  title           String
  description     String?
  destination     String?
  startDate       DateTime?        @map("start_date")
  endDate         DateTime?        @map("end_date")
  status          TripStatus       @default(draft)
  coverImageUrl   String?          @map("cover_image_url")
  budget          Decimal?         @map("budget")
  ownerId         String           @map("owner_id")
  isFavorite      Boolean          @default(false) @map("is_favorite")
  archivedAt      DateTime?        @map("archived_at")
  deletedAt       DateTime?        @map("deleted_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  owner           User             @relation("TripOwner", fields: [ownerId], references: [id])
  members         TripMember[]
  days            TripDay[]
  places          TripPlace[]
  expenses        TripExpense[]
  photos          Photo[]
  travelDocuments TravelDocument[]
  packingLists    PackingList[]

  @@map("trips")
}

model TripDay {
  id              String           @id @default(cuid())
  tripId          String           @map("trip_id")
  date            DateTime
  dayIndex        Int              @map("day_index")
  title           String?
  summary         String?
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  trip            Trip             @relation(fields: [tripId], references: [id])
  places          TripPlace[]
  photos          Photo[]
  travelDocuments TravelDocument[]

  @@unique([tripId, date])
  @@unique([tripId, dayIndex])
  @@map("trip_days")
}

model TripPlace {
  id              String           @id @default(cuid())
  tripId          String           @map("trip_id")
  tripDayId       String?          @map("trip_day_id")
  name            String
  type            TripPlaceType    @default(custom)
  address         String?
  latitude        Decimal?
  longitude       Decimal?
  startTime       DateTime?        @map("start_time")
  endTime         DateTime?        @map("end_time")
  notes           String?
  sortOrder       Int              @default(0) @map("sort_order")
  isCompleted     Boolean          @default(false) @map("is_completed")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  trip            Trip             @relation(fields: [tripId], references: [id])
  tripDay         TripDay?         @relation(fields: [tripDayId], references: [id])
  photos          Photo[]
  travelDocuments TravelDocument[]

  @@index([tripId])
  @@index([tripDayId])
  @@map("trip_places")
}

model Photo {
  id          String    @id @default(cuid())
  tripId      String    @map("trip_id")
  tripDayId   String?   @map("trip_day_id")
  tripPlaceId String?   @map("trip_place_id")
  url         String
  caption     String?
  shotAt      DateTime? @map("shot_at")
  isCover     Boolean   @default(false) @map("is_cover")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  trip      Trip       @relation(fields: [tripId], references: [id])
  tripDay   TripDay?   @relation(fields: [tripDayId], references: [id])
  tripPlace TripPlace? @relation(fields: [tripPlaceId], references: [id])

  @@index([tripId])
  @@index([tripDayId])
  @@index([tripPlaceId])
  @@map("photos")
}

model TravelDocument {
  id          String             @id @default(cuid())
  tripId      String             @map("trip_id")
  tripDayId   String?            @map("trip_day_id")
  tripPlaceId String?            @map("trip_place_id")
  type        TravelDocumentType
  title       String
  url         String
  notes       String?
  expiredAt   DateTime?          @map("expired_at")
  isReminder  Boolean            @default(false) @map("is_reminder")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  trip      Trip       @relation(fields: [tripId], references: [id])
  tripDay   TripDay?   @relation(fields: [tripDayId], references: [id])
  tripPlace TripPlace? @relation(fields: [tripPlaceId], references: [id])

  @@index([tripId])
  @@index([tripDayId])
  @@index([tripPlaceId])
  @@index([isReminder, expiredAt])
  @@map("travel_documents")
}

model PackingList {
  id        String              @id @default(cuid())
  tripId    String              @map("trip_id")
  name      String
  category  PackingListCategory
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")

  trip  Trip          @relation(fields: [tripId], references: [id])
  items PackingItem[]

  @@index([tripId])
  @@map("packing_lists")
}

model PackingItem {
  id            String  @id @default(cuid())
  packingListId String  @map("packing_list_id")
  name          String
  quantity      Int     @default(1)
  isPacked      Boolean @default(false) @map("is_packed")
  notes         String?
  orderIndex    Int     @default(0) @map("order_index")

  packingList PackingList @relation(fields: [packingListId], references: [id])

  @@index([packingListId])
  @@map("packing_items")
}

model TripExpense {
  id          String              @id @default(cuid())
  tripId      String              @map("trip_id")
  payerUserId String              @map("payer_user_id")
  title       String
  amount      Decimal
  currency    String              @default("CNY")
  category    TripExpenseCategory @default(other)
  spentAt     DateTime            @map("spent_at")
  notes       String?
  createdAt   DateTime            @default(now()) @map("created_at")
  updatedAt   DateTime            @updatedAt @map("updated_at")
  trip        Trip                @relation(fields: [tripId], references: [id])
  payer       User                @relation("ExpensePayer", fields: [payerUserId], references: [id])
  shares      TripExpenseShare[]

  @@index([tripId])
  @@index([payerUserId])
  @@map("trip_expenses")
}

model TripExpenseShare {
  id          String      @id @default(cuid())
  expenseId   String      @map("expense_id")
  userId      String      @map("user_id")
  shareAmount Decimal     @map("share_amount")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  expense     TripExpense @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user        User        @relation(fields: [userId], references: [id])

  @@unique([expenseId, userId])
  @@index([userId])
  @@map("trip_expense_shares")
}

model TripMember {
  id        String         @id @default(cuid())
  tripId    String         @map("trip_id")
  userId    String         @map("user_id")
  role      TripMemberRole @default(member)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  trip      Trip           @relation(fields: [tripId], references: [id])
  user      User           @relation(fields: [userId], references: [id])

  @@unique([tripId, userId])
  @@map("trip_members")
}
