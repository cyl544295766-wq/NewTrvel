# App
NODE_ENV=development
APP_NAME=Travel OS
APP_PORT=3000

# Web
WEB_PORT=5173
VITE_API_BASE_URL=http://localhost:3000/api
VITE_AMAP_MAP_KEY=
VITE_AMAP_SECURITY_CODE=

# Database
DATABASE_URL=postgresql://travel_os:travel_os_password@localhost:5432/travel_os

# PostgreSQL Docker
POSTGRES_USER=travel_os
POSTGRES_PASSWORD=travel_os_password
POSTGRES_DB=travel_os
POSTGRES_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth
JWT_SECRET=change_me_in_local_env
JWT_EXPIRES_IN=7d
AMAP_WEB_SERVICE_KEY=
AUTH_COOKIE_NAME=access_token

# Seed admin user
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_DISPLAY_NAME=Admin
SEED_ADMIN_PASSWORD=admin123
